# ============================================================
# Environment variables — copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# ---- Master API ----
# Empty = no API key (typical local dev). Comma-separated = require X-API-Key / UI "API key" field.
MASTER_API_KEYS=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Security ----
NODE_SHARED_SECRET=                   # shared secret between master and nodes
ALLOWED_DIRS=./workspace:./data       # colon-separated allowed file directories
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ---- LLM Provider API Keys ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ---- Ollama (local, free — default) ----
# Local server: install from ollama.com, run `ollama serve`, then `ollama pull <model>`.
# No API key needed. Leave OLLAMA_API_KEY unset/empty.
# Overrides agents.yaml base_url (e.g. Docker: OLLAMA_HOST=http://ollama:11434).
OLLAMA_HOST=http://localhost:11434
#
# Optional — only if you call Ollama’s hosted API (ollama.com), not local :11434:
# OLLAMA_API_KEY=

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Knowledge / ChromaDB ----
CHROMA_DIR=./data/chroma

# ---- Node Worker ----
NODE_ID=                              # default: hostname
NODE_HOST=                            # default: hostname
NODE_PORT=8001
MASTER_URL=http://localhost:8000
NODE_HEARTBEAT_SEC=15
AGENTS_CONFIG=./config/agents.yaml
