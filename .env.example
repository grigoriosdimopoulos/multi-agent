# ============================================================
# Environment variables — copy to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# ---- Master API ----
MASTER_API_KEYS=                      # comma-separated keys; empty = open access (dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Security ----
NODE_SHARED_SECRET=                   # shared secret between master and nodes
ALLOWED_DIRS=./workspace:./data       # colon-separated allowed file directories
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ---- LLM Provider API Keys ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ---- Ollama (local, free) ----
OLLAMA_HOST=http://localhost:11434    # override if Ollama runs on another host

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Knowledge / ChromaDB ----
CHROMA_DIR=./data/chroma

# ---- Node Worker ----
NODE_ID=                              # default: hostname
NODE_HOST=                            # default: hostname
NODE_PORT=8001
MASTER_URL=http://localhost:8000
NODE_HEARTBEAT_SEC=15
AGENTS_CONFIG=./config/agents.yaml
